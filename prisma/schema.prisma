// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  password     String
  displayName  String?
  organization String?
  role         String         @default("Subscriber")
  status       String         @default("Active")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  payments     Payment[]
  subscriptions Subscription[]
  quotations   Quotation[]
  submissions  Submission[]
  usageLogs    UsageLog[]
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String?  @unique
  paymentId String?  @unique
  amount    Float
  status    String   @default("Pending")
  method    String?  @default("Razorpay")
  
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  
  items     Json
  createdAt DateTime @default(now())
}

model Subscription {
  id         String   @id @default(uuid())
  domainId   String
  domainName String
  planName   String
  duration   String
  status     String   @default("Active")
  
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  
  startDate  DateTime @default(now())
  endDate    DateTime
  createdAt  DateTime @default(now())
}

model Quotation {
  id           String   @id
  userEmail    String
  userName     String
  organization String?
  state        String?
  items        Json
  subtotal     Float
  gstAmount    Float
  total        Float
  status       String   @default("Sent")
  
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?
  
  createdAt    DateTime @default(now())
  expiresAt    DateTime
}

model Submission {
  id              String   @id @default(uuid())
  title           String
  authors         String
  contentType     String
  subjectArea     String?  @default("General")
  fileUrl         String?
  publishingMode  String
  status          String   @default("Pending")
  
  user            User?    @relation(fields: [userId], references: [id])
  userId          String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  content         Content?
}

model Content {
  id              String   @id @default(uuid())
  title           String
  authors         String
  contentType     String
  subjectArea     String?  @default("General")
  fileUrl         String?
  publishingMode  String
  
  submission      Submission? @relation(fields: [submissionId], references: [id])
  submissionId    String?     @unique
  
  publishedAt     DateTime @default(now())
}

model AccessRequest {
  id            String   @id @default(uuid())
  institution   String
  contactPerson String
  email         String
  phone         String
  requestType   String   @default("Trial")
  status        String   @default("Pending")
  
  createdAt     DateTime @default(now())
}

model UsageLog {
  id            String   @id @default(uuid())
  action        String
  details       String?
  points        Int?     @default(0)
  
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  
  createdAt     DateTime @default(now())
}
