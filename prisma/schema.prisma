// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  password     String
  displayName  String?
  organization String?
  state        String?
  role         String         @default("Subscriber")
  status       String         @default("Active")
  isBlocked    Boolean        @default(false)
  isFirstLogin Boolean        @default(false)

  institution  Institution?   @relation(fields: [institutionId], references: [id])
  institutionId String?
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  payments              Payment[]
  subscriptions         Subscription[]
  quotations            Quotation[]
  submissions           Submission[]
  usageLogs             UsageLog[]
  subscriptionRequests  SubscriptionRequest[]
  activities            StudentActivity[]
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String?  @unique
  paymentId String?  @unique
  amount    Float
  status    String   @default("Pending")
  method    String?  @default("Razorpay")
  
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  
  items     Json
  createdAt DateTime @default(now())
}

model Subscription {
  id             String   @id @default(uuid())
  domainId       String?
  domainName     String?
  planName       String
  planType       String   @default("Monthly")   // Monthly | Yearly | Custom
  durationMonths Int      @default(1)
  duration       String?  // deprecated label field (kept for compat)
  status         String   @default("Active")   // Active | Expired | Cancelled
  
  domains        Json?    @default("[]")
  contentTypes   Json?    @default("[]")
  allowedContentTypes Json? @default("[]") // Adding for legacy compatibility
  
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  
  institution    Institution? @relation(fields: [institutionId], references: [id])
  institutionId  String?
  
  request        SubscriptionRequest? @relation(fields: [requestId], references: [id])
  requestId      String?  @unique
  
  startDate      DateTime @default(now())
  endDate        DateTime
  cancelledAt    DateTime?
  createdAt      DateTime @default(now())
}

model SubscriptionRequest {
  id             String   @id @default(uuid())
  userName       String
  email          String
  planType       String   @default("Monthly")   // Monthly | Yearly | Custom
  durationMonths Int      @default(1)
  planDescription String? // e.g. "All Domains Package"
  paymentRef     String?  // screenshot URL or payment reference
  notes          String?
  status         String   @default("Pending")   // Pending | Approved | Rejected
  rejectionNote  String?
  
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  
  subscription   Subscription?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Quotation {
  id                String   @id @default(uuid())
  userEmail         String
  userName          String
  organization      String?
  state             String?
  items             Json
  subtotal          Float
  gstAmount         Float
  total             Float
  status            String   @default("Pending")  // Pending | Approved | Paid | Cancelled

  // Dynamic pricing fields
  selectedModules   Json?    @default("[]")       // Array of ContentModule IDs selected
  pricingBreakdown  Json?    @default("{}")        // { modules: [{id, domain, contentType, price}], planType, subtotal, gst, total }
  planType          String?  @default("Monthly")   // Monthly | Quarterly | Yearly
  allowedDomain     String?  // null means all domains
  notes             String?

  user              User?    @relation(fields: [userId], references: [id])
  userId            String?

  createdAt         DateTime @default(now())
  expiresAt         DateTime
}

model ContentModule {
  id                String   @id @default(uuid())
  domain            String
  contentType       String
  totalCount        Int      @default(0)
  monthlyPrice      Float    @default(0)
  quarterlyPrice    Float    @default(0)
  yearlyPrice       Float    @default(0)
  yearlyDiscountPct Float    @default(0)   // e.g. 20 means 20% off yearly
  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt @default(now())

  @@unique([domain, contentType])
}

model Submission {

  id              String   @id @default(uuid())
  title           String
  authors         String
  contentType     String
  subjectArea     String?  @default("General")
  fileUrl         String?
  publishingMode  String
  status          String   @default("Pending")
  
  user            User?    @relation(fields: [userId], references: [id])
  userId          String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  content         Content?
}

model Content {
  id              String   @id @default(uuid())
  title           String
  description     String?
  authors         String
  domain          String?
  contentType     String
  subjectArea     String?  @default("General")
  fileUrl         String?
  thumbnailUrl    String?
  tags            Json?    @default("[]")
  price           Float?   @default(0.0)
  accessType      String   @default("Subscription")
  status          String   @default("Published")
  publishingMode  String   @default("Direct")
  views           Int      @default(0)
  
  submission      Submission? @relation(fields: [submissionId], references: [id])
  submissionId    String?     @unique
  
  publishedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())
  
  studentActivities StudentActivity[]
}

model AccessRequest {
  id            String   @id @default(uuid())
  institution   String
  contactPerson String
  email         String
  phone         String
  requestType   String   @default("Trial")
  status        String   @default("Pending")
  
  createdAt     DateTime @default(now())
}

model UsageLog {
  id            String   @id @default(uuid())
  action        String
  details       String?
  points        Int?     @default(0)
  
  user          User?    @relation(fields: [userId], references: [id])
  userId        String?
  
  createdAt     DateTime @default(now())
}

model Institution {
  id              String   @id @default(uuid())
  name            String
  subscriptionId  String?  @unique
  status          String   @default("Active")
  
  users           User[]
  subscriptions   Subscription[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StudentActivity {
  id          String   @id @default(uuid())
  
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  
  content     Content? @relation(fields: [contentId], references: [id])
  contentId   String?
  
  timeSpent   Int      @default(0)
  accessedAt  DateTime @default(now())
}

model Bundle {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  domains         Json     @default("[]")
  contentTypes    Json     @default("[]")
  price           Float    @default(0.0)
  durationMonths  Int      @default(1)
  status          String   @default("Active")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
